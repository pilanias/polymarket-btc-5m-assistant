# Polymarket CLOB auth (DO NOT COMMIT real secrets)

# ── Supabase persistence ──────────────────────────────────────────────────
# Required for trade history to survive DigitalOcean deploys.
# 1. Create a free project at https://supabase.com
# 2. Run the SQL schema from .planning/supabase-schema.sql in the SQL editor
# 3. Copy Project URL and service_role key from: Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# ─────────────────────────────────────────────────────────────────────────

# One-time only: used to derive CLOB user API creds
# PRIVATE_KEY=0x...

# After deriving creds, store them here
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# Polymarket CLOB settings
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# LIVE bot knobs (safe defaults)
# If the held outcome token trades very high (near 1.00), take profit even if plenty of time remains.
# Example: 0.90 means exit when mark >= 0.90 (90¢).
LIVE_TAKE_PROFIT_PRICE=0.9
# If true, manage exits for ALL open positions (even older tokenIDs), and do not enter until flat.
LIVE_MANAGE_ALL_POSITIONS=true

# Risk exits (used by both paper + live exit logic)
EXIT_BEFORE_END_MIN=1.50
MAX_LOSS_USD_PER_TRADE=10
LOSER_MAX_HOLD_SECONDS=120

# Live kill-switch accounting
# Daily loss baseline (USD): subtract this from today's realized PnL when applying kill-switch.
# Set this to the current realizedTodayRaw after a deployment so earlier PnL doesn't count.
LIVE_DAILY_LOSS_BASELINE_USD=

# Signature config (from Polymarket docs quickstart)
SIGNATURE_TYPE=0
FUNDER_ADDRESS=
